{
	"name": "@scidekick/cli",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"description": "Scidekick research CLI adapter and transcript rendering",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --parallel",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"dependencies": {
		"@scidekick/runtime": "workspace:*"
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./commands": {
			"types": "./src/commands/index.ts",
			"import": "./src/commands/index.ts"
		},
		"./commands/*": {
			"types": "./src/commands/*.ts",
			"import": "./src/commands/*.ts"
		},
		"./export": {
			"types": "./src/export/index.ts",
			"import": "./src/export/index.ts"
		},
		"./export/*": {
			"types": "./src/export/*.ts",
			"import": "./src/export/*.ts"
		},
		"./fixtures": {
			"types": "./src/fixtures/index.ts",
			"import": "./src/fixtures/index.ts"
		},
		"./fixtures/*": {
			"types": "./src/fixtures/*.ts",
			"import": "./src/fixtures/*.ts"
		},
		"./render": {
			"types": "./src/render/index.ts",
			"import": "./src/render/index.ts"
		},
		"./render/*": {
			"types": "./src/render/*.ts",
			"import": "./src/render/*.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
