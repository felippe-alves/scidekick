{
	"name": "@scidekick/runtime",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"description": "Scidekick runtime contracts for research events, status, and replayable state",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"scripts": {
		"check": "biome check . && bun run check:types",
		"check:types": "tsgo -p tsconfig.json --noEmit",
		"lint": "biome lint .",
		"test": "bun test --parallel",
		"fix": "biome check --write --unsafe .",
		"fmt": "biome format --write ."
	},
	"devDependencies": {
		"@types/bun": "catalog:"
	},
	"engines": {
		"bun": ">=1.3.14"
	},
	"files": [
		"src",
		"README.md",
		"CHANGELOG.md"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./events": {
			"types": "./src/events/index.ts",
			"import": "./src/events/index.ts"
		},
		"./events/*": {
			"types": "./src/events/*.ts",
			"import": "./src/events/*.ts"
		},
		"./research-store": {
			"types": "./src/research-store/index.ts",
			"import": "./src/research-store/index.ts"
		},
		"./research-store/*": {
			"types": "./src/research-store/*.ts",
			"import": "./src/research-store/*.ts"
		},
		"./research-state": {
			"types": "./src/research-state/index.ts",
			"import": "./src/research-state/index.ts"
		},
		"./research-state/*": {
			"types": "./src/research-state/*.ts",
			"import": "./src/research-state/*.ts"
		},
		"./status": {
			"types": "./src/status/index.ts",
			"import": "./src/status/index.ts"
		},
		"./status/*": {
			"types": "./src/status/*.ts",
			"import": "./src/status/*.ts"
		},
		"./*": {
			"types": "./src/*.ts",
			"import": "./src/*.ts"
		}
	}
}
